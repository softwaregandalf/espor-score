generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Game {
  id          Int          @id @default(autoincrement())
  name        String
  slug        String       @unique
  tournaments Tournament[]
  teams       Team[]
  players     Player[]
}

model Tournament {
  id        Int      @id @default(autoincrement())
  gameId    Int
  game      Game     @relation(fields: [gameId], references: [id])
  name      String
  startDate DateTime
  endDate   DateTime
  status    String
  matches   Match[]
}

model Team {
  id             Int      @id @default(autoincrement())
  gameId         Int
  game           Game     @relation(fields: [gameId], references: [id])
  name           String
  acronym        String
  logoUrl        String?
  players        Player[]
  matchesAsTeam1 Match[]  @relation("Team1Matches")
  matchesAsTeam2 Match[]  @relation("Team2Matches")
}

model Player {
  id          Int               @id @default(autoincrement())
  teamId      Int
  team        Team              @relation(fields: [teamId], references: [id])
  gameId      Int
  game        Game              @relation(fields: [gameId], references: [id])
  nickname    String
  firstName   String?
  lastName    String?
  nationality String?
  imageUrl    String?
  matchStats  PlayerMatchStat[]
}

model Match {
  id           Int               @id @default(autoincrement())
  tournamentId Int
  tournament   Tournament        @relation(fields: [tournamentId], references: [id])
  team1Id      Int
  team1        Team              @relation("Team1Matches", fields: [team1Id], references: [id])
  team2Id      Int
  team2        Team              @relation("Team2Matches", fields: [team2Id], references: [id])
  status       String
  team1Score   Int               @default(0)
  team2Score   Int               @default(0)
  startTime    DateTime

  // Evrensel MVP Alanları
  mvpNickname  String?           @default("Belirlenmedi")
  mvpRating    Float?            @default(1.0)
  mvpKills     Int?              @default(0)
  mvpDeaths    Int?              @default(0)

  // Dinamik Oyun İstatistikleri (JSON)
  gameDetails  Json?

  playerStats  PlayerMatchStat[]
}

model PlayerMatchStat {
  id       Int    @id @default(autoincrement())
  matchId  Int
  match    Match  @relation(fields: [matchId], references: [id])
  playerId Int
  player   Player @relation(fields: [playerId], references: [id])
  kills    Int    @default(0)
  deaths   Int    @default(0)
  assists  Int    @default(0)
}

// --- YENİ EKLENEN TOPLULUK VE KULLANICI MODELLERİ ---

model User {
  id        String    @id // Supabase'den gelen UUID buraya kaydedilecek
  email     String    @unique
  nickname  String    @unique
  avatarUrl String?
  role      String    @default("USER") // İleride Admin veya Pro üyelikler için
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  threads         Thread[]
  comments        Comment[]
  votes           Vote[]
  matchFavorites  MatchFavorite[]
}

model Thread {
  id        Int       @id @default(autoincrement())
  title     String
  content   String    @db.Text // Prisma'ya bunun uzun bir PostgreSQL Text'i olduğunu söyler
  category  String    // Örn: 'analytics', 'transfers', 'patches', 'general'
  gameSlug  String    // Örn: 'lol', 'val', 'cs2'. İstenirse Game modeline de bağlanabilir.
  
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  comments  Comment[]
  votes     Vote[]
}

model Comment {
  id        Int       @id @default(autoincrement())
  content   String    @db.Text
  
  threadId  Int
  thread    Thread    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  createdAt DateTime  @default(now())
}

model Vote {
  id        Int       @id @default(autoincrement())
  value     Int       // 1 (Upvote) veya -1 (Downvote)
  
  threadId  Int
  thread    Thread    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Bir kullanıcı bir konuya sadece bir kez oy verebilir
  @@unique([threadId, userId]) 
}

model MatchFavorite {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchId   String
  createdAt DateTime @default(now())

  @@unique([userId, matchId])
}